{
  "annotations": { "list": [] },
  "description": "kahzaabu observability — V2 Slice 12 (ADR 0010). Import into Grafana with a Prometheus data source named 'Prometheus' that scrapes the kahzaabu /metrics endpoint.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "title": "API request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (path) (rate(kahzaabu_api_requests_total[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "title": "API latency P95 (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (path, le) (rate(kahzaabu_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "title": "LLM cost rate (USD/h, by stage)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (stage) (rate(kahzaabu_llm_cost_usd_total[1h])) * 3600",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" },
        "overrides": []
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "title": "Fact-checks published (cumulative, by verdict)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (verdict_label) (kahzaabu_factchecks_published_total)",
          "legendFormat": "{{verdict_label}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "title": "Pipeline stage runs (last 24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (stage, status) (increase(kahzaabu_pipeline_stage_runs_total[24h]))",
          "legendFormat": "{{stage}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "title": "HTTP error rate (% of requests)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "targets": [
        {
          "expr": "100 * sum(rate(kahzaabu_api_requests_total{status=~\"5..\"}[5m])) / sum(rate(kahzaabu_api_requests_total[5m]))",
          "legendFormat": "5xx %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["kahzaabu", "fact-checking"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kahzaabu",
  "uid": "kahzaabu-overview",
