# Caddy reverse-proxy + auto-HTTPS for kahzaabu.
#
# Install on the VPS:
#   sudo apt install caddy
#   sudo cp scripts/Caddyfile /etc/caddy/Caddyfile
#   (edit the domain name below)
#   sudo systemctl restart caddy
#
# Caddy will obtain a Let's Encrypt cert automatically on first request.
# DNS A/AAAA record for the domain must point to this server first.

kahzaabu.example.com {
    # Static assets get longer caching
    @static path /static/*
    header @static Cache-Control "public, max-age=3600"

    # Robots + sitemap stay un-rate-limited
    @public path /robots.txt /favicon.ico

    # Sensible default headers
    header {
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Permissions-Policy: trim aggressively
        Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
    }

    # Don't leak server version
    header -Server
    header Server "kahzaabu"

    # Reverse-proxy to the local uvicorn
    reverse_proxy 127.0.0.1:8765 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
    }

    encode gzip zstd

    log {
        output file /var/log/caddy/kahzaabu.log {
            roll_size 50mb
            roll_keep 7
        }
        format json
    }
}
